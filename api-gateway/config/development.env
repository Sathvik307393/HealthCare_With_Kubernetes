export APP_NAME="HealthCareAPI"
export NODE_ENV="production"
export NO_COLOR=''
export SERVER_PORT="3000"
export LOG_LEVEL="info"

# Database Configuration (from root .env)
export DATABASE_HOST="${DATABASE_HOST:-postgres}"
export DATABASE_USERNAME="${DATABASE_USERNAME:-postgres}"
export DATABASE_PASSWORD="${DATABASE_PASSWORD}"
export DATABASE_NAME="gateway_db"

# CORS & Security
export ALLOWED_ORIGINS="${ALLOWED_ORIGINS:-https://app.yourdomain.com}"

# gRPC Service Hosts
export APPOINTMENT_SERVICE_HOST="appointment-service"
export APPOINTMENT_SERVICE_PORT="50051"

export DOCTOR_SERVICE_HOST="doctor-service"
export DOCTOR_SERVICE_PORT="50051"

export AUTH_SERVICE_HOST="auth-service"
export AUTH_SERVICE_PORT="50051"

export USER_SERVICE_HOST="user-service"
export USER_SERVICE_PORT="50051"
