export APP_NAME="AuthenticationService"
export NODE_ENV="production"
export LOG_LEVEL="info"

export DATABASE_HOST="${DATABASE_HOST:-postgres}"
export DATABASE_USERNAME="${DATABASE_USERNAME:-postgres}"
export DATABASE_PASSWORD="${DATABASE_PASSWORD}"
export DATABASE_NAME="auth_db"

export GRPC_SERVER_PORT="50051"

# DynamoDB Configuration
export DYNAMO_ENDPOINT="${DYNAMO_ENDPOINT:-http://dynamodb:8000}"
export DYNAMO_AWS_ACCESS_KEY_ID="${DYNAMO_AWS_ACCESS_KEY_ID}"
export DYNAMO_AWS_SECRET_ACCESS_KEY="${DYNAMO_AWS_SECRET_ACCESS_KEY}"
export DYNAMO_AWS_REGION="${DYNAMO_AWS_REGION:-us-east-1}"
export DYNAMO_TIMEOUT="5000"
export DYNAMO_MAX_RETRIES="3"
export DYNAMO_CONNECT_TIMEOUT="5000"

export SESSION_DURATION="${SESSION_DURATION:-3600000}"

export USER_SERVICE_HOST="user-service"
export USER_SERVICE_PORT="50051"
